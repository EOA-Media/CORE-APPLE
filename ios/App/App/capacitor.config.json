{
	"appId": "com.corefitness.app",
	"appName": "CORE",
	"webDir": "dist",
	"server": {
		"androidScheme": "https",
		"iosScheme": "https"
	},
	"plugins": {
		"SplashScreen": {
			"launchShowDuration": 1200,
			"backgroundColor": "#070A0F",
			"showSpinner": false
		},
		"PushNotifications": {
			"presentationOptions": [
				"badge",
				"sound",
				"alert"
			]
		},
		"SocialLogin": {
			"providers": {
				"google": true,
				"facebook": false,
				"apple": false,
				"twitter": false
			}
		}
	},
	"packageClassList": [
		"SignInWithApple",
		"PushNotificationsPlugin",
		"SocialLoginPlugin"
	]
}
